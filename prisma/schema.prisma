generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TestType {
  FABQ
  TAMPA
  PCS
  SPADI
}

model Admin {
  id        String   @id @default(uuid())
  fullName  String
  email     String   @unique
  dni       String   @unique
  password  String
  username     String   @unique
  phone        String?
  slotDuration Int      @default(45)
  createdAt    DateTime @default(now())
  pacientes    Paciente[]
  horarios     HorarioSemanal[]
  excepciones  ExcepcionHorario[]
  turnos       Turno[]
  notificaciones Notificacion[]
}

model Paciente {
  id               String    @id @default(uuid())
  fullName         String
  dni              String    @unique
  phone            String?
  email            String?
  gender           String?
  age              Int?
  height           Float?
  weight           Float?
  notes            String?
  sessionsCount    Int       @default(0)
  totalSessions    Int       @default(0)
  lastSessionDate  DateTime?
  healthInsurance  String?
  totalInvoiced    Float     @default(0)
  totalPaid        Float     @default(0)
  difference       Float     @default(0)
  isActive         Boolean   @default(true)
  dischargeDate    DateTime?
  diagnoses        String[]
  createdAt        DateTime  @default(now())
  rutinas          Rutina[]
  adminId          String?
  admin            Admin?    @relation(fields: [adminId], references: [id])
  notasClinicas    NotaClinica[]
  turnos           Turno[]
  tests            PatientTest[]
}

model PatientTest {
  id          String   @id @default(uuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  testType    TestType
  responses   Json     // { itemKey: score, ... }
  totalScore  Int
  subScores   Json?    // { FABQpa: 12, FABQw: 28 }
  createdAt   DateTime @default(now())

  @@index([pacienteId])
  @@index([testType])
}

model Ejercicio {
  id          String   @id @default(uuid())
  name        String
  description String
  categories  String[]
  videoUrl    String?
  createdAt   DateTime @default(now())
}

model Rutina {
  id          String   @id @default(uuid())
  name        String
  description String
  dias        Dia[]
  pacienteId  String?
  paciente    Paciente? @relation(fields: [pacienteId], references: [id])
  createdAt   DateTime @default(now())
}

model Dia {
  id         String            @id @default(uuid())
  name       String
  rutinaId   String
  rutina     Rutina            @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  ejercicios EjercicioEnDia[]
  createdAt  DateTime          @default(now())
}

model EjercicioEnDia {
  id         String    @id @default(uuid())
  diaId      String
  dia        Dia       @relation(fields: [diaId], references: [id], onDelete: Cascade)
  exerciseId String
  sets       Int
  reps       Int
  time       String?
  createdAt  DateTime  @default(now())
}

model NotaClinica {
  id          String   @id @default(uuid())
  title       String
  description String
  photoUrl    String?
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model HorarioSemanal {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Domingo, 1 = Lunes...
  startTime String   // ej. "08:00"
  endTime   String   // ej. "12:00"
  createdAt DateTime @default(now())
}

model ExcepcionHorario {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  date      DateTime
  isClosed  Boolean  @default(false)
  startTime String?
  endTime   String?
  createdAt DateTime @default(now())
}

model Turno {
  id         String   @id @default(uuid())
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  status     String   @default("CONFIRMED") // PENDING, CONFIRMED, CANCELLED
  createdAt  DateTime @default(now())
}

model Notificacion {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
